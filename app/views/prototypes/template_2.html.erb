<% content_for(:title) { "Budget AI — Transactions" } %>

<% content_for(:fonts) do %>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<% end %>

<% content_for(:styles) do %>
<style>
  :root {
    --bg: #faf9f6;
    --surface: #ffffff;
    --border: #e8e5df;
    --border-strong: #d0cdc7;
    --text: #1a1815;
    --text-dim: #8a857b;
    --accent: #e85d04;
    --accent-light: #fff3eb;
    --income: #15803d;
    --income-bg: #f0fdf4;
    --expense: #1a1815;
    --tag-bg: #f3f1ec;
    --hover: #f7f5f0;
  }

  body {
    font-family: 'Outfit', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* --- Top Bar --- */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 40px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .topbar-left {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .topbar-logo {
    font-weight: 700;
    font-size: 18px;
    letter-spacing: -0.5px;
    color: var(--accent);
  }

  .topbar-nav {
    display: flex;
    gap: 4px;
  }

  .topbar-link {
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-dim);
    text-decoration: none;
    transition: all 0.15s;
  }

  .topbar-link:hover { background: var(--hover); color: var(--text); }
  .topbar-link.active { background: var(--accent-light); color: var(--accent); }

  /* --- Content --- */
  .content { max-width: 1100px; margin: 0 auto; padding: 40px; }

  .content-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 32px;
  }

  .content-title {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .content-subtitle {
    font-size: 14px;
    color: var(--text-dim);
    margin-top: 4px;
  }

  /* Filters */
  .filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .filter-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-dim);
    background: var(--surface);
    cursor: pointer;
    transition: all 0.15s;
  }

  .filter-chip:hover { border-color: var(--text); color: var(--text); }
  .filter-chip.active { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
  .filter-chip .material-icons { font-size: 16px; }

  /* Search */
  .search-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface);
    margin-bottom: 24px;
    transition: border-color 0.2s;
  }

  .search-bar:focus-within { border-color: var(--accent); }

  .search-bar .material-icons { color: var(--text-dim); font-size: 20px; }

  .search-input {
    border: none;
    outline: none;
    font-family: inherit;
    font-size: 14px;
    width: 100%;
    background: transparent;
    color: var(--text);
  }

  .search-input::placeholder { color: var(--text-dim); }

  .search-shortcut {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 3px 8px;
    background: var(--tag-bg);
    border-radius: 6px;
    color: var(--text-dim);
    white-space: nowrap;
  }

  /* --- Table --- */
  .txn-table {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  .txn-table-header {
    display: grid;
    grid-template-columns: 44px 2fr 1fr 1fr 120px;
    gap: 16px;
    padding: 12px 20px;
    border-bottom: 1px solid var(--border);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-dim);
  }

  .txn-row {
    display: grid;
    grid-template-columns: 44px 2fr 1fr 1fr 120px;
    gap: 16px;
    padding: 16px 20px;
    align-items: center;
    border-bottom: 1px solid var(--border);
    transition: background 0.1s;
    cursor: pointer;
  }

  .txn-row:last-child { border-bottom: none; }
  .txn-row:hover { background: var(--hover); }

  .txn-icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    background: var(--tag-bg);
  }

  .txn-desc-name {
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 2px;
  }

  .txn-desc-id {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-dim);
  }

  .txn-account {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
  }

  .account-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .current-dot { background: #00539B; }
  .savings-dot { background: #7C3AED; }
  .credit-dot { background: #FF6B6B; }

  .txn-category {
    font-size: 12px;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 6px;
    background: var(--tag-bg);
    display: inline-block;
  }

  .txn-amount-cell {
    text-align: right;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 700;
  }

  .txn-amount-cell.positive {
    color: var(--income);
    background: var(--income-bg);
    padding: 4px 10px;
    border-radius: 8px;
    display: inline-block;
    margin-left: auto;
  }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-top: 1px solid var(--border);
    font-size: 13px;
    color: var(--text-dim);
  }

  .page-buttons {
    display: flex;
    gap: 4px;
  }

  .page-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    background: var(--surface);
    cursor: pointer;
    transition: all 0.15s;
  }

  .page-btn:hover { background: var(--hover); }
  .page-btn.active { background: var(--text); color: var(--surface); border-color: var(--text); }

  /* Animations */
  @keyframes slideIn {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .txn-row {
    animation: slideIn 0.3s ease-out both;
  }

  .txn-row:nth-child(2) { animation-delay: 0.03s; }
  .txn-row:nth-child(3) { animation-delay: 0.06s; }
  .txn-row:nth-child(4) { animation-delay: 0.09s; }
  .txn-row:nth-child(5) { animation-delay: 0.12s; }
  .txn-row:nth-child(6) { animation-delay: 0.15s; }
  .txn-row:nth-child(7) { animation-delay: 0.18s; }
  .txn-row:nth-child(8) { animation-delay: 0.21s; }

  @media (max-width: 768px) {
    .content { padding: 20px; }
    .txn-table-header { display: none; }
    .txn-row { grid-template-columns: 40px 1fr auto; }
    .txn-row > :nth-child(3),
    .txn-row > :nth-child(4) { display: none; }
    .topbar { padding: 12px 20px; }
    .topbar-nav { display: none; }
  }
</style>
<% end %>

<!-- Top Bar -->
<div class="topbar">
  <div class="topbar-left">
    <span class="topbar-logo">Budget AI</span>
    <nav class="topbar-nav">
      <a href="<%= prototype_path(1) %>" class="topbar-link">Dashboard</a>
      <a href="#" class="topbar-link active">Transactions</a>
      <a href="<%= prototype_path(3) %>" class="topbar-link">Import</a>
      <a href="<%= prototype_path(4) %>" class="topbar-link">Insights</a>
      <a href="<%= prototype_path(5) %>" class="topbar-link">Accounts</a>
    </nav>
  </div>
</div>

<div class="content">
  <div class="content-header">
    <div>
      <h1 class="content-title">Transactions</h1>
      <p class="content-subtitle">1,247 transactions &middot; Feb 2026</p>
    </div>
    <div class="filters">
      <span class="filter-chip active">
        <span class="material-icons">filter_list</span>
        All
      </span>
      <span class="filter-chip">
        <span class="material-icons">arrow_downward</span>
        Income
      </span>
      <span class="filter-chip">
        <span class="material-icons">arrow_upward</span>
        Expenses
      </span>
      <span class="filter-chip">
        <span class="material-icons">swap_horiz</span>
        Transfers
      </span>
    </div>
  </div>

  <!-- Search -->
  <div class="search-bar">
    <span class="material-icons">search</span>
    <input type="text" class="search-input" placeholder="Search transactions...">
    <span class="search-shortcut">&#8984;K</span>
  </div>

  <!-- Table -->
  <div class="txn-table">
    <div class="txn-table-header">
      <span></span>
      <span>Description</span>
      <span>Account</span>
      <span>Category</span>
      <span style="text-align: right">Amount</span>
    </div>

    <% [
      { emoji: '💰', name: 'Monthly Salary', id: 'tx_feb_001', account: 'Current', dot: 'current', cat: 'Income', amount: '+£4,250.00', positive: true, date: 'Feb 1' },
      { emoji: '🏠', name: 'Rent - Flat 4B', id: 'tx_feb_002', account: 'Current', dot: 'current', cat: 'Housing', amount: '-£1,200.00', positive: false, date: 'Feb 1' },
      { emoji: '🛒', name: 'Tesco Express', id: 'tx_feb_003', account: 'Savings', dot: 'savings', cat: 'Groceries', amount: '-£47.83', positive: false, date: 'Feb 3' },
      { emoji: '☕', name: 'Pret A Manger', id: 'tx_feb_004', account: 'Savings', dot: 'savings', cat: 'Dining', amount: '-£4.50', positive: false, date: 'Feb 3' },
      { emoji: '🚇', name: 'TfL Contactless', id: 'tx_feb_005', account: 'Savings', dot: 'savings', cat: 'Transport', amount: '-£6.80', positive: false, date: 'Feb 4' },
      { emoji: '📱', name: 'Spotify Premium', id: 'tx_feb_006', account: 'Credit', dot: 'credit', cat: 'Subscriptions', amount: '-£10.99', positive: false, date: 'Feb 4' },
      { emoji: '⚡', name: 'Octopus Energy', id: 'tx_feb_007', account: 'Current', dot: 'current', cat: 'Bills', amount: '-£87.40', positive: false, date: 'Feb 5' },
      { emoji: '🍕', name: 'Dominos Pizza', id: 'tx_feb_008', account: 'Savings', dot: 'savings', cat: 'Dining', amount: '-£18.99', positive: false, date: 'Feb 6' }
    ].each do |t| %>
      <div class="txn-row">
        <div class="txn-icon-wrap"><%= t[:emoji] %></div>
        <div>
          <div class="txn-desc-name"><%= t[:name] %></div>
          <div class="txn-desc-id"><%= t[:id] %> &middot; <%= t[:date] %></div>
        </div>
        <div class="txn-account">
          <span class="account-dot <%= t[:dot] %>-dot"></span>
          <%= t[:account] %>
        </div>
        <div><span class="txn-category"><%= t[:cat] %></span></div>
        <div class="txn-amount-cell <%= t[:positive] ? 'positive' : '' %>"><%= t[:amount] %></div>
      </div>
    <% end %>

    <div class="pagination">
      <span>Showing 1-8 of 1,247</span>
      <div class="page-buttons">
        <span class="page-btn active">1</span>
        <span class="page-btn">2</span>
        <span class="page-btn">3</span>
        <span class="page-btn">&hellip;</span>
        <span class="page-btn">156</span>
      </div>
    </div>
  </div>
</div>
