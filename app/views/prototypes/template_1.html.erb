<% content_for(:title) { "Budget AI — Dashboard" } %>

<% content_for(:fonts) do %>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
<% end %>

<% content_for(:styles) do %>
<style>
  :root {
    --bg: #0a0f0d;
    --surface: #111916;
    --surface-2: #182320;
    --surface-3: #1e2d28;
    --border: #2a3f38;
    --text: #e8f0ec;
    --text-dim: #7a9a8e;
    --accent: #00e5a0;
    --accent-glow: rgba(0, 229, 160, 0.15);
    --income: #00e5a0;
    --expense: #ff6b6b;
    --radius: 16px;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Ambient glow */
  body::before {
    content: '';
    position: fixed;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0, 229, 160, 0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .shell {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: 100vh;
    position: relative;
    z-index: 1;
  }

  /* --- Sidebar --- */
  .sidebar {
    background: var(--surface);
    border-right: 1px solid var(--border);
    padding: 32px 20px;
    display: flex;
    flex-direction: column;
    gap: 32px;
    position: sticky;
    top: 0;
    height: 100vh;
  }

  .logo {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
    letter-spacing: -0.5px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent);
  }

  .nav { display: flex; flex-direction: column; gap: 4px; }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 12px;
    color: var(--text-dim);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s;
  }

  .nav-item:hover { background: var(--surface-2); color: var(--text); }
  .nav-item.active {
    background: var(--accent-glow);
    color: var(--accent);
    border: 1px solid rgba(0, 229, 160, 0.2);
  }
  .nav-item .material-icons { font-size: 20px; }

  .sidebar-footer {
    margin-top: auto;
    padding: 16px;
    background: var(--surface-2);
    border-radius: 12px;
    font-size: 13px;
    color: var(--text-dim);
  }

  .sidebar-footer strong { color: var(--text); display: block; margin-bottom: 2px; }

  /* --- Main Content --- */
  .main {
    padding: 40px;
    max-width: 1200px;
  }

  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 40px;
  }

  .page-title {
    font-family: 'DM Serif Display', serif;
    font-size: 32px;
    letter-spacing: -0.5px;
  }

  .page-date {
    font-size: 14px;
    color: var(--text-dim);
    background: var(--surface);
    padding: 8px 16px;
    border-radius: 100px;
    border: 1px solid var(--border);
  }

  /* --- Stat Cards --- */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
  }

  .stat-card:hover { border-color: var(--accent); }

  .stat-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
  }

  .stat-card.income::after { background: linear-gradient(90deg, var(--income), transparent); }
  .stat-card.expense::after { background: linear-gradient(90deg, var(--expense), transparent); }
  .stat-card.balance::after { background: linear-gradient(90deg, var(--accent), transparent); }
  .stat-card.savings::after { background: linear-gradient(90deg, #a78bfa, transparent); }

  .stat-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-dim);
    margin-bottom: 12px;
  }

  .stat-value {
    font-family: 'DM Serif Display', serif;
    font-size: 28px;
    letter-spacing: -1px;
  }

  .stat-change {
    font-size: 12px;
    margin-top: 8px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .stat-change.up { color: var(--income); }
  .stat-change.down { color: var(--expense); }

  /* --- Charts Row --- */
  .charts-row {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 16px;
    margin-bottom: 40px;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
  }

  .card-title {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-dim);
    margin-bottom: 24px;
  }

  /* Fake chart bars */
  .chart-bars {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    height: 180px;
    padding-top: 20px;
  }

  .chart-bar-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    height: 100%;
    justify-content: flex-end;
  }

  .chart-bar {
    width: 100%;
    border-radius: 6px 6px 0 0;
    min-height: 8px;
    transition: all 0.3s;
  }

  .chart-bar.income-bar { background: var(--income); opacity: 0.7; }
  .chart-bar.income-bar:hover { opacity: 1; }
  .chart-bar.expense-bar { background: var(--expense); opacity: 0.7; }
  .chart-bar.expense-bar:hover { opacity: 1; }

  .chart-label {
    font-size: 11px;
    color: var(--text-dim);
    text-align: center;
  }

  /* Donut */
  .donut-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .donut-svg { width: 160px; height: 160px; }

  .donut-legend {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .legend-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 13px;
  }

  .legend-left { display: flex; align-items: center; gap: 8px; }

  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .legend-amount { color: var(--text-dim); font-variant-numeric: tabular-nums; }

  /* --- Transactions --- */
  .txn-list { display: flex; flex-direction: column; }

  .txn-item {
    display: grid;
    grid-template-columns: 40px 1fr auto;
    gap: 16px;
    align-items: center;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }

  .txn-item:last-child { border-bottom: none; }

  .txn-icon {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
  }

  .txn-icon.groceries { background: rgba(0, 229, 160, 0.1); color: var(--income); }
  .txn-icon.transport { background: rgba(167, 139, 250, 0.1); color: #a78bfa; }
  .txn-icon.dining { background: rgba(255, 107, 107, 0.1); color: var(--expense); }
  .txn-icon.bills { background: rgba(251, 191, 36, 0.1); color: #fbbf24; }
  .txn-icon.salary { background: rgba(0, 229, 160, 0.15); color: var(--income); }

  .txn-name { font-weight: 500; font-size: 14px; }
  .txn-meta { font-size: 12px; color: var(--text-dim); margin-top: 2px; }

  .txn-amount { font-variant-numeric: tabular-nums; font-weight: 600; font-size: 14px; text-align: right; }
  .txn-amount.positive { color: var(--income); }
  .txn-amount.negative { color: var(--text); }

  /* Animations */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .stat-card, .card, .txn-item {
    animation: fadeUp 0.4s ease-out both;
  }

  .stat-card:nth-child(1) { animation-delay: 0.05s; }
  .stat-card:nth-child(2) { animation-delay: 0.1s; }
  .stat-card:nth-child(3) { animation-delay: 0.15s; }
  .stat-card:nth-child(4) { animation-delay: 0.2s; }

  .charts-row .card:first-child { animation-delay: 0.25s; }
  .charts-row .card:last-child { animation-delay: 0.3s; }

  @media (max-width: 1024px) {
    .shell { grid-template-columns: 1fr; }
    .sidebar { display: none; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .charts-row { grid-template-columns: 1fr; }
  }
</style>
<% end %>

<div class="shell">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="logo">
      <span class="logo-dot"></span>
      Budget AI
    </div>

    <nav class="nav">
      <a href="#" class="nav-item active">
        <span class="material-icons">dashboard</span>
        Dashboard
      </a>
      <a href="<%= prototype_path(2) %>" class="nav-item">
        <span class="material-icons">receipt_long</span>
        Transactions
      </a>
      <a href="<%= prototype_path(3) %>" class="nav-item">
        <span class="material-icons">cloud_upload</span>
        Import
      </a>
      <a href="<%= prototype_path(4) %>" class="nav-item">
        <span class="material-icons">auto_awesome</span>
        AI Insights
      </a>
      <a href="<%= prototype_path(5) %>" class="nav-item">
        <span class="material-icons">account_balance</span>
        Accounts
      </a>
    </nav>

    <div class="sidebar-footer">
      <strong>User</strong>
      3 accounts connected
    </div>
  </aside>

  <!-- Main -->
  <div class="main">
    <div class="page-header">
      <h1 class="page-title">Dashboard</h1>
      <span class="page-date">February 2026</span>
    </div>

    <!-- Stats -->
    <div class="stats">
      <div class="stat-card income">
        <div class="stat-label">Income</div>
        <div class="stat-value">&pound;4,250.00</div>
        <div class="stat-change up">
          <span class="material-icons" style="font-size:14px">trending_up</span>
          +12% vs last month
        </div>
      </div>
      <div class="stat-card expense">
        <div class="stat-label">Expenses</div>
        <div class="stat-value">&pound;2,847.63</div>
        <div class="stat-change down">
          <span class="material-icons" style="font-size:14px">trending_down</span>
          +5% vs last month
        </div>
      </div>
      <div class="stat-card balance">
        <div class="stat-label">Net Balance</div>
        <div class="stat-value">&pound;1,402.37</div>
        <div class="stat-change up">
          <span class="material-icons" style="font-size:14px">trending_up</span>
          +8% vs last month
        </div>
      </div>
      <div class="stat-card savings">
        <div class="stat-label">Savings Rate</div>
        <div class="stat-value">33%</div>
        <div class="stat-change up">
          <span class="material-icons" style="font-size:14px">trending_up</span>
          Target: 30%
        </div>
      </div>
    </div>

    <!-- Charts -->
    <div class="charts-row">
      <div class="card">
        <div class="card-title">Income vs Expenses</div>
        <div class="chart-bars">
          <% [
            { month: 'Sep', inc: 60, exp: 50 },
            { month: 'Oct', inc: 65, exp: 55 },
            { month: 'Nov', inc: 70, exp: 48 },
            { month: 'Dec', inc: 80, exp: 70 },
            { month: 'Jan', inc: 75, exp: 60 },
            { month: 'Feb', inc: 85, exp: 57 }
          ].each do |m| %>
            <div class="chart-bar-group">
              <div class="chart-bar income-bar" style="height: <%= m[:inc] %>%"></div>
              <div class="chart-bar expense-bar" style="height: <%= m[:exp] %>%"></div>
              <span class="chart-label"><%= m[:month] %></span>
            </div>
          <% end %>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Spending by Category</div>
        <div class="donut-wrap">
          <svg class="donut-svg" viewBox="0 0 42 42">
            <circle cx="21" cy="21" r="15.9" fill="none" stroke="#2a3f38" stroke-width="4"/>
            <circle cx="21" cy="21" r="15.9" fill="none" stroke="#00e5a0" stroke-width="4"
                    stroke-dasharray="35 65" stroke-dashoffset="25" stroke-linecap="round"/>
            <circle cx="21" cy="21" r="15.9" fill="none" stroke="#ff6b6b" stroke-width="4"
                    stroke-dasharray="25 75" stroke-dashoffset="90" stroke-linecap="round"/>
            <circle cx="21" cy="21" r="15.9" fill="none" stroke="#a78bfa" stroke-width="4"
                    stroke-dasharray="20 80" stroke-dashoffset="65" stroke-linecap="round"/>
            <circle cx="21" cy="21" r="15.9" fill="none" stroke="#fbbf24" stroke-width="4"
                    stroke-dasharray="15 85" stroke-dashoffset="45" stroke-linecap="round"/>
          </svg>
          <div class="donut-legend">
            <% [
              { name: 'Bills & Utilities', color: '#00e5a0', amount: '£980' },
              { name: 'Groceries', color: '#ff6b6b', amount: '£710' },
              { name: 'Transport', color: '#a78bfa', amount: '£560' },
              { name: 'Dining Out', color: '#fbbf24', amount: '£420' }
            ].each do |c| %>
              <div class="legend-item">
                <span class="legend-left">
                  <span class="legend-dot" style="background: <%= c[:color] %>"></span>
                  <%= c[:name] %>
                </span>
                <span class="legend-amount"><%= c[:amount] %></span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Recent Transactions -->
    <div class="card">
      <div class="card-title">Recent Transactions</div>
      <div class="txn-list">
        <% [
          { icon: 'salary', emoji: '💰', name: 'Monthly Salary', meta: 'Current · Feb 1', amount: '+£4,250.00', positive: true },
          { icon: 'bills', emoji: '🏠', name: 'Rent Payment', meta: 'Current · Feb 1', amount: '-£1,200.00', positive: false },
          { icon: 'groceries', emoji: '🛒', name: 'Tesco Express', meta: 'Savings · Feb 3', amount: '-£47.83', positive: false },
          { icon: 'transport', emoji: '🚇', name: 'TfL Travel', meta: 'Savings · Feb 4', amount: '-£6.80', positive: false },
          { icon: 'dining', emoji: '🍕', name: 'Pizza Express', meta: 'Savings · Feb 5', amount: '-£32.50', positive: false }
        ].each do |t| %>
          <div class="txn-item">
            <div class="txn-icon <%= t[:icon] %>"><%= t[:emoji] %></div>
            <div>
              <div class="txn-name"><%= t[:name] %></div>
              <div class="txn-meta"><%= t[:meta] %></div>
            </div>
            <div class="txn-amount <%= t[:positive] ? 'positive' : 'negative' %>"><%= t[:amount] %></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
