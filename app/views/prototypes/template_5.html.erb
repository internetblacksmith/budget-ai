<% content_for(:title) { "Budget AI — Accounts" } %>

<% content_for(:fonts) do %>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<% end %>

<% content_for(:styles) do %>
<style>
  :root {
    --bg: #f5f3ef;
    --surface: #ffffff;
    --surface-dim: #edeae4;
    --border: #ddd8d0;
    --text: #1a1613;
    --text-dim: #7d7568;
    --current: #00539B;
    --current-bg: #edf4fa;
    --savings: #7C3AED;
    --savings-bg: #f3eeff;
    --credit: #FF6B6B;
    --credit-bg: #fff1f1;
  }

  body {
    font-family: 'Manrope', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* Nav */
  .nav-bar {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 20px 48px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    font-family: 'Libre Baskerville', serif;
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.5px;
  }

  .nav-links { display: flex; gap: 4px; margin-left: auto; }

  .nav-link {
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-dim);
    text-decoration: none;
    transition: all 0.15s;
  }

  .nav-link:hover { color: var(--text); background: var(--surface-dim); }
  .nav-link.active { color: var(--text); background: var(--surface-dim); }

  /* Page */
  .page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px;
  }

  .page-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 40px;
  }

  .page-title {
    font-family: 'Libre Baskerville', serif;
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .page-subtitle {
    font-size: 15px;
    color: var(--text-dim);
    margin-top: 6px;
  }

  .total-balance-badge {
    text-align: right;
  }

  .total-balance-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-dim);
    margin-bottom: 4px;
  }

  .total-balance-value {
    font-family: 'Libre Baskerville', serif;
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -1px;
  }

  /* Account Cards */
  .accounts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 48px;
  }

  .account-card {
    background: var(--surface);
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: all 0.25s;
    cursor: pointer;
  }

  .account-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }

  .account-header {
    padding: 28px 28px 0;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .account-logo {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 18px;
    letter-spacing: -0.5px;
  }

  .current-logo { background: var(--current-bg); color: var(--current); }
  .savings-logo { background: var(--savings-bg); color: var(--savings); }
  .credit-logo { background: var(--credit-bg); color: var(--credit); }

  .account-name {
    font-weight: 700;
    font-size: 16px;
  }

  .account-type {
    font-size: 12px;
    color: var(--text-dim);
    margin-top: 2px;
  }

  .account-body {
    padding: 24px 28px;
  }

  .account-balance-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-dim);
    margin-bottom: 4px;
  }

  .account-balance {
    font-family: 'Libre Baskerville', serif;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .account-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 20px;
  }

  .account-stat {
    padding: 12px;
    border-radius: 12px;
    background: var(--surface-dim);
  }

  .account-stat-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-dim);
    margin-bottom: 4px;
  }

  .account-stat-value {
    font-weight: 700;
    font-size: 15px;
    font-variant-numeric: tabular-nums;
  }

  .account-stat-value.income { color: #16a34a; }
  .account-stat-value.expense { color: var(--text); }

  .account-footer {
    padding: 16px 28px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    color: var(--text-dim);
  }

  .account-footer-link {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--text);
    font-weight: 600;
    text-decoration: none;
  }

  .account-footer-link .material-icons { font-size: 16px; }

  /* Accent bar at top of card */
  .account-card .account-accent {
    height: 4px;
  }

  .accent-current { background: linear-gradient(90deg, var(--current), #4a90d9); }
  .accent-savings { background: linear-gradient(90deg, var(--savings), #a78bfa); }
  .accent-credit { background: linear-gradient(90deg, var(--credit), #ff9999); }

  /* Breakdown table */
  .breakdown-section { margin-top: 8px; }

  .breakdown-title {
    font-family: 'Libre Baskerville', serif;
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .breakdown-table {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
  }

  .breakdown-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    padding: 14px 24px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-dim);
    background: var(--surface-dim);
    border-bottom: 1px solid var(--border);
  }

  .breakdown-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    padding: 18px 24px;
    align-items: center;
    border-bottom: 1px solid var(--border);
    transition: background 0.1s;
  }

  .breakdown-row:last-child { border-bottom: none; }
  .breakdown-row:hover { background: var(--surface-dim); }

  .breakdown-account {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 600;
    font-size: 14px;
  }

  .breakdown-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .breakdown-cell {
    font-variant-numeric: tabular-nums;
    font-size: 14px;
    font-weight: 500;
  }

  .breakdown-cell.income { color: #16a34a; }
  .breakdown-cell.balance { font-weight: 700; }

  .breakdown-bar-cell { padding-right: 20px; }

  .balance-bar-track {
    height: 8px;
    background: var(--surface-dim);
    border-radius: 4px;
    overflow: hidden;
  }

  .balance-bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.5s ease;
  }

  .bar-current { background: var(--current); }
  .bar-savings { background: var(--savings); }
  .bar-credit { background: var(--credit); }

  /* Total row */
  .breakdown-total {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    padding: 18px 24px;
    font-weight: 700;
    font-size: 14px;
    background: var(--surface-dim);
    border-top: 2px solid var(--border);
  }

  /* Animations */
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(24px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .account-card:nth-child(1) { animation: cardIn 0.5s ease-out 0.1s both; }
  .account-card:nth-child(2) { animation: cardIn 0.5s ease-out 0.2s both; }
  .account-card:nth-child(3) { animation: cardIn 0.5s ease-out 0.3s both; }

  .breakdown-section { animation: cardIn 0.5s ease-out 0.4s both; }

  @media (max-width: 900px) {
    .accounts-grid { grid-template-columns: 1fr; }
    .page { padding: 24px; }
    .page-header { flex-direction: column; align-items: flex-start; gap: 16px; }
    .total-balance-badge { text-align: left; }
    .breakdown-header, .breakdown-row, .breakdown-total {
      grid-template-columns: 2fr 1fr 1fr;
    }
    .breakdown-bar-cell, .breakdown-header > :nth-child(5),
    .breakdown-row > :nth-child(5), .breakdown-total > :nth-child(5) { display: none; }
    .nav-bar { padding: 16px 24px; }
    .nav-links { display: none; }
  }
</style>
<% end %>

<!-- Nav -->
<nav class="nav-bar">
  <span class="nav-logo">Budget AI</span>
  <div class="nav-links">
    <a href="<%= prototype_path(1) %>" class="nav-link">Dashboard</a>
    <a href="<%= prototype_path(2) %>" class="nav-link">Transactions</a>
    <a href="<%= prototype_path(3) %>" class="nav-link">Import</a>
    <a href="<%= prototype_path(4) %>" class="nav-link">Insights</a>
    <a href="#" class="nav-link active">Accounts</a>
  </div>
</nav>

<div class="page">
  <div class="page-header">
    <div>
      <h1 class="page-title">Accounts</h1>
      <p class="page-subtitle">3 connected accounts across 3 banks</p>
    </div>
    <div class="total-balance-badge">
      <div class="total-balance-label">Total Balance</div>
      <div class="total-balance-value">&pound;8,432.17</div>
    </div>
  </div>

  <!-- Account Cards -->
  <div class="accounts-grid">
    <!-- Credit Card -->
    <div class="account-card">
      <div class="account-accent accent-credit"></div>
      <div class="account-header">
        <div class="account-logo credit-logo">C</div>
        <div>
          <div class="account-name">Credit Card</div>
          <div class="account-type">Credit Account</div>
        </div>
      </div>
      <div class="account-body">
        <div class="account-balance-label">Balance</div>
        <div class="account-balance">&pound;1,847.23</div>
        <div class="account-stats">
          <div class="account-stat">
            <div class="account-stat-label">Income</div>
            <div class="account-stat-value income">+&pound;450.00</div>
          </div>
          <div class="account-stat">
            <div class="account-stat-label">Spent</div>
            <div class="account-stat-value expense">-&pound;892.41</div>
          </div>
        </div>
      </div>
      <div class="account-footer">
        <span>Last synced 2h ago</span>
        <a href="#" class="account-footer-link">
          View <span class="material-icons">arrow_forward</span>
        </a>
      </div>
    </div>

    <!-- Current Account -->
    <div class="account-card">
      <div class="account-accent accent-current"></div>
      <div class="account-header">
        <div class="account-logo current-logo">C</div>
        <div>
          <div class="account-name">Current Account</div>
          <div class="account-type">Current Account</div>
        </div>
      </div>
      <div class="account-body">
        <div class="account-balance-label">Balance</div>
        <div class="account-balance">&pound;3,210.50</div>
        <div class="account-stats">
          <div class="account-stat">
            <div class="account-stat-label">Income</div>
            <div class="account-stat-value income">+&pound;4,250.00</div>
          </div>
          <div class="account-stat">
            <div class="account-stat-label">Spent</div>
            <div class="account-stat-value expense">-&pound;1,487.40</div>
          </div>
        </div>
      </div>
      <div class="account-footer">
        <span>Last synced 2h ago</span>
        <a href="#" class="account-footer-link">
          View <span class="material-icons">arrow_forward</span>
        </a>
      </div>
    </div>

    <!-- Savings Account -->
    <div class="account-card">
      <div class="account-accent accent-savings"></div>
      <div class="account-header">
        <div class="account-logo savings-logo">S</div>
        <div>
          <div class="account-name">Savings Account</div>
          <div class="account-type">Savings Account</div>
        </div>
      </div>
      <div class="account-body">
        <div class="account-balance-label">Balance</div>
        <div class="account-balance">&pound;3,374.44</div>
        <div class="account-stats">
          <div class="account-stat">
            <div class="account-stat-label">Income</div>
            <div class="account-stat-value income">+&pound;500.00</div>
          </div>
          <div class="account-stat">
            <div class="account-stat-label">Spent</div>
            <div class="account-stat-value expense">-&pound;0.00</div>
          </div>
        </div>
      </div>
      <div class="account-footer">
        <span>Last synced 2h ago</span>
        <a href="#" class="account-footer-link">
          View <span class="material-icons">arrow_forward</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Breakdown Table -->
  <div class="breakdown-section">
    <h2 class="breakdown-title">Monthly Breakdown</h2>
    <div class="breakdown-table">
      <div class="breakdown-header">
        <span>Account</span>
        <span>Income</span>
        <span>Expenses</span>
        <span>Balance</span>
        <span>Share</span>
      </div>

      <% [
        { name: 'Credit Card', color: 'credit', dot: '#FF6B6B', income: '£450.00', expenses: '£892.41', balance: '£1,847.23', pct: 22 },
        { name: 'Current Account', color: 'current', dot: '#00539B', income: '£4,250.00', expenses: '£1,487.40', balance: '£3,210.50', pct: 38 },
        { name: 'Savings Account', color: 'savings', dot: '#7C3AED', income: '£500.00', expenses: '£0.00', balance: '£3,374.44', pct: 40 }
      ].each do |a| %>
        <div class="breakdown-row">
          <div class="breakdown-account">
            <span class="breakdown-dot" style="background: <%= a[:dot] %>;"></span>
            <%= a[:name] %>
          </div>
          <div class="breakdown-cell income"><%= a[:income] %></div>
          <div class="breakdown-cell"><%= a[:expenses] %></div>
          <div class="breakdown-cell balance"><%= a[:balance] %></div>
          <div class="breakdown-bar-cell">
            <div class="balance-bar-track">
              <div class="balance-bar-fill bar-<%= a[:color] %>" style="width: <%= a[:pct] %>%"></div>
            </div>
          </div>
        </div>
      <% end %>

      <div class="breakdown-total">
        <span>Total</span>
        <span style="color: #16a34a;">&pound;5,200.00</span>
        <span>&pound;2,379.81</span>
        <span>&pound;8,432.17</span>
        <span></span>
      </div>
    </div>
  </div>
</div>
