# Budget AI Development Environment Template
# Copy this to .env.local and fill in your values

# ============================================================================
# GOOGLE API CONFIGURATION (Required for Emma import)
# ============================================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google_oauth2/callback

# SSL Certificate Configuration (for development)
# If you get SSL certificate errors with Google API:
# Option 1: Auto-detect system certificates (recommended)
#   Leave these commented out - the app will find them automatically

# Option 2: Specify custom certificate file
# SSL_CERT_FILE=/path/to/cert.pem

# Option 3: Skip SSL verification (DEVELOPMENT ONLY - NOT RECOMMENDED)
# SKIP_SSL_VERIFY=1

# ============================================================================
# LLM CONFIGURATION
# ============================================================================
# Use local Ollama for AI insights
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral  # or your preferred model

# ============================================================================
# RAILS CONFIGURATION
# ============================================================================
RAILS_ENV=development
RAILS_LOG_LEVEL=debug

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit .env.local to git - it contains secrets
# 2. Use .env.local.example as a template for other developers
# 3. In production, use proper environment variables or secret management
