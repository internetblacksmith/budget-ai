#!/usr/bin/env ruby
# frozen_string_literal: true

# Check if TTY gems are installed
begin
  require 'bundler/setup'
  require 'tty-prompt'
  require 'tty-screen'
  require 'pastel'
  require 'ostruct'
rescue LoadError => e
  puts "❌ Missing required gems for interactive menu"
  puts ""
  puts "Please run: bundle install"
  puts "Or use the simple menu: make menu-simple"
  puts ""
  puts "Error: #{e.message}"
  exit 1
end

# Interactive menu for Budget AI
class BudgetAIMenu
  def initialize
    @prompt = TTY::Prompt.new
    @pastel = Pastel.new
    @commands = build_commands
  end

  def run
    begin
      loop do
        clear_screen
        show_header
        
        choices = build_menu_choices
        
        # Calculate available height for menu dynamically
        # Use almost entire terminal height, leaving room for header and help text
        terminal_height = TTY::Screen.height
        # Reserve lines: header (3) + prompt (1) + help (1) + bottom margin (1)
        reserved_lines = 6
        items_per_page = [terminal_height - reserved_lines, 10].max
        
        # If terminal is very tall, show all items without pagination
        if items_per_page >= choices.reject { |c| c[:disabled] }.count
          items_per_page = choices.count
        end
        
        selection = @prompt.select(
          @pastel.cyan.bold("Choose an action:"),
          choices,
          per_page: items_per_page,
          filter: true,
          cycle: true,
          help: @pastel.yellow("↑↓ Navigate  • Type to filter  • Enter to select  • Esc to quit"),
          show_help: :always
        )
        
        break if selection == :quit
        
        execute_command(selection)
        # Loop continues here - back to menu
      end
    rescue Interrupt
      # Handle Ctrl+C gracefully
      puts "\n"
    end
    
    puts @pastel.green.bold("👋 Goodbye!")
    exit 0
  end

  private

  def clear_screen
    system('clear') || system('cls')
  end

  def show_header
    puts @pastel.cyan.bold("═" * TTY::Screen.width)
    puts @pastel.cyan.bold("  🚀 Budget AI - Interactive Menu")
    puts @pastel.cyan.bold("═" * TTY::Screen.width)
  end

  def build_commands
    {
      # Development
      server: {
        name: "🚀 Start Rails server",
        command: "make server",
        category: :development,
        description: "Start the development server with auto port detection"
