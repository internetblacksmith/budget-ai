        command: "make check-port",
        category: :help,
        description: "Check if port 3000 is available"
      }
    }
  end

  def build_menu_choices
    choices = []
    
    # Group commands by category
    categories = {
       development: { icon: "🚀", label: "Development" },
       testing: { icon: "🧪", label: "Testing" },
       quality: { icon: "✨", label: "Code Quality" },
       database: { icon: "🗄️", label: "Database" },
       accounts: { icon: "🏦", label: "Account Analysis" },
       ai: { icon: "🤖", label: "AI/LLM (Ollama)" },
       maintenance: { icon: "🔧", label: "Maintenance" },
       help: { icon: "📚", label: "Help & Info" }
    }
    
    categories.each do |cat_key, cat_info|
      cat_commands = @commands.select { |_, cmd| cmd[:category] == cat_key }
      next if cat_commands.empty?
      
      # Add category separator
      choices << { 
        name: @pastel.yellow.bold("─── #{cat_info[:icon]} #{cat_info[:label]} ───"),
        disabled: ""
      }
      
      # Add commands in this category
      cat_commands.each do |key, cmd|
        choices << {
          name: "  #{cmd[:name]}",
          value: key,
          disabled: false
        }
      end
    end
    
    # Add quit option at the end
    choices << { 
      name: @pastel.yellow.bold("─── System ───"),
      disabled: ""
    }
    choices << {
      name: "  ❌ Quit",
      value: :quit
    }
    
    choices
  end

  def execute_command(key)
    return unless @commands[key]
    
    cmd = @commands[key]
    
    clear_screen
    puts @pastel.green.bold("▶ Executing: #{cmd[:name]}")
    puts @pastel.cyan("  Command: #{cmd[:command]}")
    puts @pastel.bright_black("  #{cmd[:description]}")
    puts @pastel.cyan("─" * TTY::Screen.width)
    puts
    
    # Execute the command based on its type
    case key
    when :server, :demo, :console
      # These commands take over the terminal completely
      puts @pastel.yellow("Starting #{cmd[:name]}...")
      puts @pastel.bright_black("Use Ctrl+C to stop and return to menu")
      puts
      system(cmd[:command])
      # After server stops, return to menu
    when :ollama_chat
      # Interactive chat exits on its own
      system(cmd[:command])
    when :test_all, :test_unit, :cucumber, :coverage
      # Test commands need to show all output
      system(cmd[:command])
      show_test_summary
    when :lint, :fix, :quality, :commit_check
      # Quality commands
      system(cmd[:command])
    else
      # All other commands
      if should_show_spinner?(key)
        run_with_spinner(cmd[:command])
      else
        system(cmd[:command])
      end
    end
    
    # Wait for user input before returning to menu
    puts
    puts @pastel.cyan("─" * TTY::Screen.width)
    print @pastel.yellow("Press Enter to return to menu (or Ctrl+C to exit)...")
    
    # Clear any buffered input and wait for fresh input
    $stdin.flush if $stdin.respond_to?(:flush)
    input = $stdin.gets
    
    # If user pressed Ctrl+D or similar, exit
    exit 0 if input.nil?
  end
  
  def show_test_summary
    # Show a nice summary after tests run
    if $?.success?
      puts
      puts @pastel.green.bold("✅ Tests passed successfully!")
    else
      puts
      puts @pastel.red.bold("❌ Some tests failed. Check the output above.")
    end
  end

  def should_show_spinner?(key)
    # Don't show spinner for interactive commands that need user input
    non_spinner_commands = [:db_reset, :db_clean, :ollama_setup, :ollama_chat]
    !non_spinner_commands.include?(key)
  end

  def run_with_spinner(command)
    require 'tty-spinner'
    
    spinner = TTY::Spinner.new("[:spinner] Running...", format: :dots)
    spinner.auto_spin
    
    success = system(command)
    
    if success
      spinner.success(@pastel.green(" Done!"))
    else
      spinner.error(@pastel.red(" Failed!"))
    end
    
    success
  end
end

# Check if running directly
if __FILE__ == $0
  begin
    menu = BudgetAIMenu.new
    menu.run
  rescue Interrupt
    puts "\n👋 Goodbye!"
    exit 0
  rescue StandardError => e
    puts "\n❌ Error: #{e.message}"
    puts "Returning to simple menu..."
    exit 1
  end
end