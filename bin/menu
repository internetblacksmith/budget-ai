         name: "⚙️ Start background job worker",
         command: "make jobs",
         category: :development,
         description: "Start Solid Queue background job processor"
       },
       console: {
         name: "💻 Rails console",
         command: "make console",
         category: :development,
         description: "Open Rails console (with privacy warning)"
       },
       migrate: {
         name: "📊 Run migrations",
         command: "make migrate",
         category: :development,
         description: "Apply pending database migrations"
       },
       
      # Testing
      test_all: {
        name: "🧪 Run all tests (RSpec + Cucumber)",
        command: "make test",
        category: :testing,
        description: "Run complete test suite"
      },
      test_unit: {
        name: "🔬 Run unit tests (RSpec)",
        command: "make test-unit",
        category: :testing,
