        name: "🔧 Auto-fix code style",
        command: "make fix",
        category: :quality,
        description: "Auto-fix Rubocop violations"
      },
      quality: {
        name: "✨ Full quality check",
        command: "make quality-check",
        category: :quality,
        description: "Run all quality checks (tests + lint + analysis)"
      },
      commit_check: {
        name: "✅ Pre-commit check",
        command: "make commit-check",
        category: :quality,
        description: "Verify code is ready to commit"
      },
      flay: {
        name: "👥 Check code duplication",
        command: "make flay",
        category: :quality,
        description: "Detect duplicate code with Flay"
      },
      reek: {
        name: "👃 Check code smells",
        command: "make reek",
        category: :quality,
        description: "Detect code smells with Reek"
      },
