      },
      test_integration: {
        name: "🌐 Run integration tests (Cucumber)",
        command: "make cucumber",
        category: :testing,
        description: "Run Cucumber feature tests"
      },
      coverage: {
        name: "📈 Test coverage report",
        command: "make coverage",
        category: :testing,
        description: "Run tests with coverage analysis"
      },
      
      # Code Quality
      lint: {
        name: "🔍 Run linter (Rubocop)",
        command: "make lint",
        category: :quality,
        description: "Check code style violations"
      },
