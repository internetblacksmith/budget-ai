# Budget AI Environment Variables
# Copy this file to .env.development and fill in your values

# Google OAuth Configuration (Required for Emma import)
# Get these from https://console.cloud.google.com
GOOGLE_OAUTH_CLIENT_ID=your_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret_here

# Local LLM Configuration (Optional - for AI features)
# Default values work with local Ollama installation
LLM_HOST=localhost
LLM_PORT=11434
LLM_MODEL=llama2

# Rails Configuration
RAILS_ENV=development
PORT=3000
